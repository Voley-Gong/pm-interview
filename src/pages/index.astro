---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allQuestions = await getCollection('questions');
const base = import.meta.env.BASE_URL;

const categories = [
  { id: 'product-thinking', name: '产品思维', icon: '🧠', desc: '认知框架、用户价值导向、概率性决策' },
  { id: 'requirement-management', name: '需求管理', icon: '📋', desc: '需求收集、优先级排序、评审流程、PRD' },
  { id: 'user-research', name: '用户研究', icon: '🔍', desc: '用户画像、场景分析、JTBD、调研方法' },
  { id: 'data-metrics', name: '数据与指标', icon: '📊', desc: 'DAU/留存/LTV/CAC、A/B 测试、数据驱动决策' },
  { id: 'strategy', name: '产品策略', icon: '🎯', desc: '竞品分析、产品定位、MVP 验证、商业化' },
  { id: 'communication', name: '协作与沟通', icon: '🤝', desc: '跨部门协作、无职权影响力、向上管理' },
  { id: 'tech-to-pm', name: '技术转PM', icon: '🚀', desc: '认知转变、常见陷阱、转型路径、面试实战' },
];

const levelMap: Record<number, string> = { 1: '入门', 2: '进阶', 3: '高级', 4: '深度' };
const levelCounts: Record<string, number> = {};
for (const q of allQuestions) {
  const key = `${levelMap[q.data.level]}`;
  levelCounts[key] = (levelCounts[key] || 0) + 1;
}

const catCounts: Record<string, number> = {};
for (const q of allQuestions) {
  catCounts[q.data.category] = (catCounts[q.data.category] || 0) + 1;
}
---

<BaseLayout title="首页">
  <div class="hero">
    <h1>🚀 产品经理面试指南</h1>
    <p>
      产品思维 / 需求管理 / 用户研究 / 数据指标 · 技术转PM实战 · 系统化进阶
    </p>
    <div class="hero-stats">
      <div class="hero-stat">
        <div class="num">{allQuestions.length}</div>
        <div class="label">面试题</div>
      </div>
      <div class="hero-stat">
        <div class="num">{categories.length}</div>
        <div class="label">分类</div>
      </div>
      <div class="hero-stat">
        <div class="num">4</div>
        <div class="label">深度层级</div>
      </div>
    </div>
  </div>

  <div class="section-title">📂 知识分类</div>
  <div class="category-grid">
    {categories.map((cat) => (
      <a href={`${base}category/${cat.id}/`} class="category-card">
        <div class="cat-icon">{cat.icon}</div>
        <h3>{cat.name}</h3>
        <div class="cat-desc">{cat.desc}</div>
        <div class="cat-count">{catCounts[cat.id] || 0} 道题目</div>
      </a>
    ))}
  </div>
</BaseLayout>
